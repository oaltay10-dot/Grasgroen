# Kopieer dit bestand naar ".env" en zet je echte sleutels hieronder.

# Voor de chatbot — gratis sleutel via: https://aistudio.google.com/apikey
GEMINI_API_KEY=zet-hier-je-sleutel

# Voor echte vluchtprijzen — gratis account via: https://developers.amadeus.com
AMADEUS_API_KEY=zet-hier-je-amadeus-key
AMADEUS_API_SECRET=zet-hier-je-amadeus-secret
